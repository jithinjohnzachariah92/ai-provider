{
  "name": "@jz92/ai-provider",
  "version": "0.6.1",
  "description": "Environment-aware AI provider for portfolio projects. Local dev → Ollama, deployed → any cloud provider. Zero config — just install and use.",
  "author": "jz92",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "modelfiles-template",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "NODE_ENV=development npx tsx --tsconfig tsconfig.test.json test/smoke.ts",
    "setup:local": "bash scripts/setup-local.sh",
    "prepublishOnly": "npm run build && npm run type-check"
  },
  "dependencies": {
    "ai": "^7.0.0",
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/openai": "^3.0.0"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "optionalDependencies": {
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/groq": "^3.0.0",
    "@ai-sdk/mistral": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "@types/node": "^20.0.0",
    "zod": "^4.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/groq": "^3.0.0",
    "@ai-sdk/mistral": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "ollama",
    "anthropic",
    "openai",
    "google",
    "groq",
    "mistral",
    "vercel-ai-sdk",
    "llm",
    "provider"
  ]
}
